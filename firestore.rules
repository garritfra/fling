rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    function signedIn() { return request.auth != null; }

    function isMember(hid) {
      return signedIn()
        && exists(/databases/$(db)/documents/households/$(hid)/members/$(request.auth.uid));
    }

    // Users can read & write their own user doc (current Flutter behaviour).
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Households + nested data: any household member can read & write.
    // NOTE(phase-0): the create carve-outs below are deliberately loose to
    // mirror today's client behaviour. The /members/{uid} rule lets ANY
    // signed-in user add themselves to ANY household, not just brand-new
    // ones. This is a known issue; Phase 2 replaces the carve-out with the
    // first-class invite flow. See docs/superpowers/specs/2026-04-24-fling-rewrite-design.md §6.4.
    match /households/{hid} {
      allow read, write: if isMember(hid)
                         || (signedIn() && request.method == 'create');

      match /members/{uid} {
        allow read, write: if isMember(hid)
                           || (signedIn() && request.auth.uid == uid && request.method == 'create');
      }

      match /lists/{lid}/{document=**} {
        allow read, write: if isMember(hid);
      }

      match /templates/{tid}/{document=**} {
        allow read, write: if isMember(hid);
      }
    }
  }
}
